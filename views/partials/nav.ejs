<nav class="navbar">
  <div class="nav-brand">
    <a href="/dashboard">SendReed</a>
  </div>
  <% if (user) { %>
  <div class="nav-links">
    <a href="/dashboard"<%= typeof currentPath !== 'undefined' && currentPath === '/dashboard' ? ' class="active"' : '' %>>Dashboard</a>
    <a href="/contacts"<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/contacts') ? ' class="active"' : '' %>><%= typeof contactLabel !== 'undefined' ? contactLabel : 'Contacts' %></a>
    <a href="/campaign"<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/campaign') ? ' class="active"' : '' %>>Campaigns</a>
    <% if (user.role === 'realestate' || user.role === 'admin') { %>
      <a href="/realestate"<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/realestate') ? ' class="active"' : '' %>>Real Estate</a>
    <% } %>
    <% if (user.role === 'admin') { %>
      <a href="/admin/users"<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin') ? ' class="active"' : '' %>>Users</a>
      <a href="/admin/fields"<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/fields') ? ' class="active"' : '' %>>Fields</a>
    <% } %>
    <span class="nav-user"><%= user.name %> (<%= user.role %>)</span>
    <a href="/auth/logout" class="nav-logout">Logout</a>
  </div>
  <% } %>
</nav>
<% if (user && user.role === 'admin') { %>
<%
  // Don't show acting-as banner on admin-only pages
  var isAdminOnlyPage = (typeof currentPath !== 'undefined') && (currentPath.startsWith('/admin/users') || currentPath.startsWith('/admin/fields'));

  // Filter users based on current page
  var filteredUsers = [];
  if (typeof allUsers !== 'undefined' && allUsers.length > 0) {
    if (typeof currentPath !== 'undefined' && currentPath.startsWith('/realestate')) {
      // On RE page, only show RE users
      filteredUsers = allUsers.filter(function(u) { return u.role === 'realestate'; });
    } else {
      // On other pages, show all non-admin users
      filteredUsers = allUsers.filter(function(u) { return u.role !== 'admin'; });
    }
  }
%>
<% if (!isAdminOnlyPage && filteredUsers.length > 0) { %>
<div class="acting-as-banner">
  <form method="POST" action="/admin/act-as" class="acting-as-form">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <label for="acting-as-select">Acting as:</label>
    <select name="user_id" id="acting-as-select" onchange="this.form.submit()">
      <option value="">— Select a user —</option>
      <% filteredUsers.forEach(function(u) { %>
        <option value="<%= u.id %>" <%= (typeof actingUser !== 'undefined' && actingUser && actingUser.id === u.id) ? 'selected' : '' %>><%= u.name %> (<%= u.role %>)</option>
      <% }); %>
    </select>
    <% if (typeof actingUser !== 'undefined' && actingUser) { %>
      <span class="acting-as-indicator">Managing <strong><%= actingUser.name %></strong>'s data</span>
    <% } else { %>
      <span class="acting-as-warning">Select a user to manage their data</span>
    <% } %>
  </form>
  <% if (typeof actingUser !== 'undefined' && actingUser) { %>
    <form method="POST" action="/admin/act-as/clear" class="acting-as-clear">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="btn btn-sm btn-secondary">Clear</button>
    </form>
  <% } %>
</div>
<% } %>
<% } %>
