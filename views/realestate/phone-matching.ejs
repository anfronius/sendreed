<%- include('../layout-header', { title: 'Phone & Email Matching' }) %>

<div class="page-header">
  <h1>Phone & Email Matching</h1>
  <div class="page-actions">
    <button type="button" class="btn btn-large btn-primary<%= (counts.autoConfirmed + counts.confirmed) > 0 ? '' : ' hidden' %>" id="apply-all-btn"
      data-count="<%= counts.autoConfirmed + counts.confirmed %>">
      Apply All Confirmed (<%= counts.autoConfirmed + counts.confirmed %>)
    </button>
    <form method="POST" action="/realestate/matching/rerun" style="display:inline;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-large btn-secondary">Re-run Matching</button>
    </form>
    <form method="POST" action="/realestate/matching/reset" style="display:inline;"
      onsubmit="return confirm('This will undo ALL applied matches and clear any phone/email data that came from matching. Are you sure?');">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-large btn-danger">Reset All Matches</button>
    </form>
    <a href="/realestate/import-vcard" class="btn btn-large btn-upload">Import Contacts List</a>
  </div>
</div>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-number"><%= counts.total %></div>
    <div class="stat-label">Total Contacts</div>
  </div>
  <div class="stat-card">
    <div class="stat-number text-success"><%= counts.matched %></div>
    <div class="stat-label">Matched</div>
  </div>
  <div class="stat-card">
    <div class="stat-number" style="color:var(--color-warning-text);"><%= counts.review %></div>
    <div class="stat-label">Needs Review</div>
  </div>
  <div class="stat-card">
    <div class="stat-number text-danger"><%= counts.unmatched %></div>
    <div class="stat-label">No Match</div>
  </div>
</div>

<input type="hidden" name="_csrf" value="<%= csrfToken %>">

<% if (counts.total === 0) { %>
  <div class="empty-state">
    <p>No contacts need phone/email data. <a href="/realestate/import-vcard">Import a contacts list</a> to start matching.</p>
  </div>
<% } else { %>

<!-- Section 1: Auto-Matched (high confidence, not yet applied) -->
<% if (autoConfirmed.length > 0) { %>
<div class="match-section match-section-green" id="section-confirmed">
  <h2>Auto-Matched <span class="count-badge"><%= autoConfirmed.length %></span></h2>
  <p class="match-section-desc">These names closely match your imported contacts list. They'll be applied when you click "Apply All Confirmed".</p>
  <div class="match-list">
    <% autoConfirmed.forEach(function(m) { %>
    <div class="match-card" data-match-id="<%= m.match_id %>">
      <div class="match-card-left">
        <div class="match-contact-name"><%= [m.c_first, m.c_last].filter(Boolean).join(' ') %></div>
        <% if (m.c_address) { %><div class="match-contact-detail"><%= m.c_address %></div><% } %>
        <div class="match-contact-detail"><%= m.c_purchase_date ? 'Sale Date: ' + m.c_purchase_date : 'No Sale Date' %></div>
      </div>
      <div class="match-card-arrow">←</div>
      <div class="match-card-right">
        <div class="match-imported-name"><%= m.ic_name || [m.ic_first, m.ic_last].filter(Boolean).join(' ') %></div>
        <div class="match-imported-details">
          <% if (m.ic_phone) { %><span>Phone: <%= m.ic_phone %></span><% } %>
          <% if (m.ic_email) { %><span>Email: <%= m.ic_email %></span><% } %>
        </div>
      </div>
      <div class="match-card-actions">
        <span class="confidence-badge confidence-high"><%= m.confidence_score %>%</span>
        <button class="btn btn-sm btn-danger skip-match-btn" data-match-id="<%= m.match_id %>">Remove</button>
      </div>
    </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Section: Confirmed & Ready to Apply -->
<div class="match-section match-section-blue<%= confirmed.length === 0 ? ' hidden' : '' %>" id="section-applied">
  <h2>Confirmed & Ready to Apply <span class="count-badge"><%= confirmed.length %></span></h2>
  <p class="match-section-desc">These matches have been confirmed. Click "Apply All Confirmed" to save them to your contacts.</p>
  <div class="match-list">
    <% confirmed.forEach(function(m) { %>
    <div class="match-card match-card-applied" data-match-id="<%= m.match_id %>">
      <div class="match-card-left">
        <div class="match-contact-name"><%= [m.c_first, m.c_last].filter(Boolean).join(' ') %></div>
        <% if (m.c_address) { %><div class="match-contact-detail"><%= m.c_address %></div><% } %>
        <div class="match-contact-detail"><%= m.c_purchase_date ? 'Sale Date: ' + m.c_purchase_date : 'No Sale Date' %></div>
      </div>
      <div class="match-card-arrow">←</div>
      <div class="match-card-right">
        <div class="match-imported-name"><%= m.ic_name || [m.ic_first, m.ic_last].filter(Boolean).join(' ') %></div>
        <div class="match-imported-details">
          <% if (m.ic_phone) { %><span>Phone: <%= m.ic_phone %></span><% } %>
          <% if (m.ic_email) { %><span>Email: <%= m.ic_email %></span><% } %>
        </div>
      </div>
      <div class="match-card-actions">
        <span class="confidence-badge confidence-high">Confirmed</span>
        <button class="btn btn-sm btn-danger skip-match-btn" data-match-id="<%= m.match_id %>">Remove</button>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Section 2: Needs Review (low confidence) -->
<% if (needsReview.length > 0) { %>
<div class="match-section match-section-yellow" id="section-review">
  <h2>Needs Review <span class="count-badge"><%= needsReview.length %></span></h2>
  <p class="match-section-desc">These are possible matches but the names aren't an exact fit. Review each one and confirm or skip.</p>
  <div class="match-list">
    <% needsReview.forEach(function(m) { %>
    <div class="match-card" data-match-id="<%= m.match_id %>">
      <div class="match-card-left">
        <div class="match-contact-name"><%= [m.c_first, m.c_last].filter(Boolean).join(' ') %></div>
        <% if (m.c_address) { %><div class="match-contact-detail"><%= m.c_address %></div><% } %>
        <div class="match-contact-detail"><%= m.c_purchase_date ? 'Sale Date: ' + m.c_purchase_date : 'No Sale Date' %></div>
      </div>
      <div class="match-card-arrow">?</div>
      <div class="match-card-right">
        <div class="match-imported-name"><%= m.ic_name || [m.ic_first, m.ic_last].filter(Boolean).join(' ') %></div>
        <div class="match-imported-details">
          <% if (m.ic_phone) { %><span>Phone: <%= m.ic_phone %></span><% } %>
          <% if (m.ic_email) { %><span>Email: <%= m.ic_email %></span><% } %>
        </div>
      </div>
      <div class="match-card-actions">
        <span class="confidence-badge confidence-low"><%= m.confidence_score %>%</span>
        <button class="btn btn-sm btn-primary confirm-match-btn" data-match-id="<%= m.match_id %>">Confirm</button>
        <button class="btn btn-sm btn-danger skip-match-btn" data-match-id="<%= m.match_id %>">Skip</button>
      </div>
    </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Section 3: Unmatched (no matching contact found in imports) -->
<% if (unmatched.length > 0) { %>
<div class="match-section match-section-red" id="section-unmatched">
  <h2>No Match Found <span class="count-badge"><%= unmatched.length %></span></h2>
  <p class="match-section-desc">These clients are missing phone or email and no match was found in your imported contacts. You can search and assign one manually.</p>
  <div class="match-list">
    <% unmatched.forEach(function(m) { %>
    <div class="match-card" data-contact-id="<%= m.contact_id %>">
      <div class="match-card-left">
        <div class="match-contact-name"><%= [m.c_first, m.c_last].filter(Boolean).join(' ') %></div>
        <% if (m.c_address) { %><div class="match-contact-detail"><%= m.c_address %></div><% } %>
        <div class="match-contact-detail"><%= m.c_purchase_date ? 'Sale Date: ' + m.c_purchase_date : 'No Sale Date' %></div>
      </div>
      <div class="match-card-right" style="flex:1;">
        <div class="manual-match-form">
          <input type="text" class="contact-search-input" placeholder="Search imported contacts by name..."
            data-contact-id="<%= m.contact_id %>">
          <div class="contact-search-results" data-contact-id="<%= m.contact_id %>"></div>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
</div>
<% } %>

<% } %>

<a href="/realestate" class="btn btn-link mt-2">Back to Real Estate</a>

<script>window.CSRF_TOKEN = '<%= csrfToken %>';</script>
<%- include('../layout-footer', { scripts: ['/js/matching.js'] }) %>
