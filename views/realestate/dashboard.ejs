<%- include('../layout-header', { title: 'Real Estate' }) %>

<h1>Real Estate</h1>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-number"><%= stats.pending_lookup %></div>
    <div class="stat-label">Properties Pending Lookup</div>
  </div>
  <div class="stat-card">
    <div class="stat-number" style="color:var(--color-warning-text);"><%= stats.to_be_matched %></div>
    <div class="stat-label">Clients to be Matched</div>
  </div>
  <div class="stat-card">
    <div class="stat-number text-success"><%= stats.confirmed %></div>
    <div class="stat-label">Confirmed Clients</div>
  </div>
</div>

<h2>Upcoming Anniversaries</h2>
<% if (upcomingAnniversaries.length > 0) { %>
<div class="anniversary-preview">
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Years</th>
        <th>Property</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% upcomingAnniversaries.forEach(function(a) { %>
      <tr>
        <td><%= a.first_name %> <%= a.last_name %></td>
        <td><%= a.years %> yr<%= a.years !== 1 ? 's' : '' %></td>
        <td><%= a.property_address %></td>
        <td><%= a.anniversary_date %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <a href="/realestate/anniversaries" class="btn btn-sm btn-secondary mt-1">View All Anniversaries</a>
</div>
<% } else { %>
<p class="text-muted mb-2">No upcoming anniversaries this week.
  <a href="/realestate/anniversaries">View Anniversaries</a>
</p>
<% } %>

<h2>Quick Actions</h2>
<div class="action-links">
  <a href="/realestate/import-crmls" class="btn btn-large btn-upload">Import CRMLS Data</a>
  <a href="/realestate/import-vcard" class="btn btn-large btn-upload">Import Contacts List</a>
  <a href="/realestate/lookup" class="btn btn-large btn-secondary">Realist Lookup</a>
  <a href="/realestate/matching" class="btn btn-large btn-secondary">Phone Matching</a>
  <form method="POST" action="/realestate/contacts/dedup" style="display:inline;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-large btn-secondary"
      onclick="return confirm('This will remove duplicate contacts, keeping the one with the latest purchase date. Continue?');">
      Deduplicate Clients
    </button>
  </form>
</div>

<%- include('../layout-footer', { scripts: [] }) %>
